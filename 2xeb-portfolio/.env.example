# Copy this file to `.env.local` and fill in the values.
# All VITE_* vars are exposed to the client bundle, so only put public values here.
# (Server-side secrets — GROQ_API_KEY, RESEND_API_KEY, SPOTIFY_* — live in Supabase
#  Edge Function secrets, never in this file.)

# Supabase project URL
VITE_SUPABASE_URL=https://zrawfgpjfkohjaqcfgrd.supabase.co

# Supabase Edge Functions base URL
VITE_SUPABASE_FUNCTIONS_URL=https://zrawfgpjfkohjaqcfgrd.supabase.co/functions/v1
# For local function development with the Supabase CLI:
# VITE_SUPABASE_FUNCTIONS_URL=http://localhost:54321/functions/v1

# Supabase anon (public) key — safe to expose in client code.
# Find it in: Supabase Dashboard > Project Settings > API > Project API keys > anon public
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: set to "true" to enable verbose debug logging in the console.
VITE_DEBUG=false
